# Copy this file to .env and fill in your values

# Server
NODE_ENV=development
PORT=3001

# Database — PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/patient_emr_db

# JWT — use a strong random string in production (min 32 chars)
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRATION=8h

# CORS — set to your frontend URL
CORS_ORIGIN=http://localhost:3000

# Frontend URL — used in email links
FRONTEND_URL=http://localhost:3000

# Email (SMTP) — leave blank to use Ethereal test emails in development
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="MediCore EMR <noreply@emr.health>"

# Session timeout in milliseconds (8 hours)
SESSION_TIMEOUT=28800000
